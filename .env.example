# PostgreSQL (Docker compose exposes 5433 to avoid clashing with a local 5432)
DATABASE_URL=postgresql+psycopg://fermentor:fermentor@localhost:5433/fermentor

# Embedding model (free / open-source, runs locally on CPU)
# bge-m3 and multilingual-e5-large are 1024-dim; e5-small is 384-dim.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# FER repository OAI-PMH endpoint (use the mods metadata prefix)
OAI_BASE_URL=https://repozitorij.fer.unizg.hr/oai/

# CORS allowed origins for the API, comma-separated. In production set this to
# the frontend URL; *.vercel.app previews are matched by a regex in the app.
CORS_ORIGINS=http://localhost:5173

# Sentry error monitoring. Empty/absent = disabled (local dev, tests).
SENTRY_DSN=

# Level of the structured request log (fermentor logger): DEBUG | INFO | WARNING
LOG_LEVEL=INFO
